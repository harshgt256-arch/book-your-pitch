# ============================================
# BOOKING API — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Google Cloud (Sheets + Calendar) ───────
# 1. Go to https://console.cloud.google.com/ → Create a new project
# 2. Enable Google Sheets API and Google Calendar API
# 3. Go to IAM & Admin → Service Accounts → Create a new service account
# 4. Generate a JSON key and download it
# 5. Set the path below or paste the JSON contents
GOOGLE_SERVICE_ACCOUNT_FILE=service-account-key.json
# OR paste the JSON directly (for production):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# 6. Share your Google Sheet with the service account email (Editor)
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id_here
# 7. For Calendar: note the Calendar ID (default is 'primary' or a specific calendar email)
GOOGLE_CALENDAR_ID=primary

# ─── Twilio (WhatsApp) ──────────────────────
# 1. Sign up at https://www.twilio.com/try-twilio
# 2. Get Account SID and Auth Token from Twilio Console
# 3. Enable WhatsApp Sandbox or request production access
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
# Your Twilio WhatsApp sender number (with whatsapp: prefix used in code)

# ─── Email (Gmail SMTP) ─────────────────────
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the app password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_16_chars
SMTP_FROM_NAME=Book Your Pitch

# ─── Deployed URL (auto-populated by Render) ─
# Render auto-injects RENDER_EXTERNAL_URL with your app's URL.
# No need to manually set this — it's read automatically.
# For local testing, leave blank.
RENDER_EXTERNAL_URL=

# ─── API Config ─────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# ─── Business Rules ─────────────────────────
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=19
SLOT_DURATION_HOURS=1
GST_RATE=0.18

# ─── Default Pricing (INR per hour) ─────────
PRICE_CRICKET=1500
PRICE_FOOTBALL=1200
PRICE_PICKLEBALL=800
PRICE_BADMINTON=600
PRICE_TENNIS=1000
PRICE_DEFAULT=1000
